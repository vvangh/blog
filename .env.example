# 可选：隐私友好分析（Umami 或兼容脚本）
# 不填则不注入任何分析脚本
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=

# 可选：Giscus 评论（四项齐全才渲染；缺一则文末不显示评论区）
# 在 https://giscus.app 配置仓库 Discussions 后复制
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=
# 可选：pathname | url | title | og:title（默认 pathname）
PUBLIC_GISCUS_MAPPING=

# 可选：Webmentions（见 docs/webmentions.md）
PUBLIC_WEBMENTION_ENDPOINT=
PUBLIC_WEBMENTION_API=

# 可选：Newsletter 表单 action（见 docs/newsletter.md）
PUBLIC_NEWSLETTER_ACTION=
