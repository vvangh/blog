---
/**
 * 全站默认布局：主题 boot、语言、OG、分析、顶栏与页脚。
 * 页面外请经 `@/layouts/SiteLayout` 导入。
 */
import "@/styles/global.css";
import { SITE_DESCRIPTION, SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";
import { getThemeBootScript } from "@/lib/theme";
import { getA11yBootScript } from "@/lib/a11y";
import { DEFAULT_LOCALE, translate, type Locale } from "@/lib/i18n";
import { absolutePageUrl, ogImagePath } from "@/lib/og";
import { resolveCanonicalOrigin } from "@/lib/domains";
import { resolveWebmentionEndpoint, readWebmentionEnvFromImportMeta } from "@/lib/webmentions";
import { SiteHeader } from "@/components/SiteHeader";
import { Analytics } from "@/components/Analytics";
import { SplashScreen } from "@/components/SplashScreen";
import { BackgroundLayer } from "@/components/BackgroundLayer";
import { NowPlaying } from "@/components/NowPlaying";
import { A11yCheatsheet } from "@/components/A11yCheatsheet";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  /** OG 卡片 slug，对应 /og/<slug>.png */
  ogSlug?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  locale = DEFAULT_LOCALE,
  ogSlug = "home",
} = Astro.props;
const pageTitle = title ? `${title} · ${SITE_NAME_ZH}` : `${SITE_NAME_ZH} · ${SITE_TAGLINE}`;
const base = import.meta.env.BASE_URL;
const themeBoot = getThemeBootScript();
const a11yBoot = getA11yBootScript();
const year = new Date().getFullYear();
const canonical = absolutePageUrl(Astro.url.pathname);
const ogImageAbs = new URL(ogImagePath(ogSlug), resolveCanonicalOrigin()).href;
const webmentionEndpoint = resolveWebmentionEndpoint(readWebmentionEnvFromImportMeta());
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {webmentionEndpoint ? <link rel="webmention" href={webmentionEndpoint} /> : null}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME_ZH} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}og-default.png`} />
    <meta name="theme-color" content="#0d9488" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&family=IBM+Plex+Sans:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&family=Outfit:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline set:html={themeBoot} />
    <script is:inline set:html={a11yBoot} />
    <Analytics />
  </head>
  <body class="min-h-screen font-sans antialiased">
    <BackgroundLayer client:load />
    <SplashScreen
      client:load
      brand={translate(locale, "splash.brand")}
      skipLabel={translate(locale, "splash.skip")}
    />
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-hl-bg focus:px-3 focus:py-2 focus:text-hl-fg focus:shadow"
    >
      {translate(locale, "skip.toMain")}
    </a>
    <SiteHeader locale={locale} />
    <main
      id="main"
      class="mx-auto w-full max-w-5xl px-4 py-8"
      data-pagefind-body
      data-pagefind-meta={`title:${pageTitle}`}
    >
      <slot />
    </main>
    <footer
      class="mx-auto w-full max-w-5xl px-4 pt-4 pb-14 text-sm text-hl-muted"
      data-pagefind-ignore
    >
      <div class="border-t border-hl-border pt-8">
        <NowPlaying locale={locale} />
        <p>{translate(locale, "footer.rights", { year })}</p>
        <p class="mt-1">{translate(locale, "footer.license")}</p>
      </div>
    </footer>
    <A11yCheatsheet
      client:load
      title={translate(locale, "a11y.helpTitle")}
      openLabel={translate(locale, "a11y.helpOpen")}
      closeLabel={translate(locale, "a11y.helpClose")}
      body={translate(locale, "a11y.helpBody")}
    />
  </body>
</html>
