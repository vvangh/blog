---
/**
 * 全站默认布局：主题 boot、语言、OG、分析、顶栏与页脚。
 * 页面外请经 `@/layouts/SiteLayout` 导入。
 */
import "@/styles/global.css";
import { SITE_DESCRIPTION, SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";
import { getThemeBootScript } from "@/lib/theme";
import { getA11yBootScript } from "@/lib/a11y";
import { DEFAULT_LOCALE, translate, type Locale } from "@/lib/i18n";
import { absolutePageUrl, ogImagePath } from "@/lib/og";
import { resolveCanonicalOrigin } from "@/lib/domains";
import { resolveWebmentionEndpoint, readWebmentionEnvFromImportMeta } from "@/lib/webmentions";
import { SiteHeader } from "@/components/SiteHeader";
import { Analytics } from "@/components/Analytics";
import { SplashScreen } from "@/components/SplashScreen";
import { BackgroundLayer } from "@/components/BackgroundLayer";
import { NowPlaying } from "@/components/NowPlaying";
import { SiteFab } from "@/components/SiteFab";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  /** OG 卡片 slug，对应 /og/<slug>.png */
  ogSlug?: string;
  /** 首页：顶栏透明双态 + 允许全出血 Hero 槽 */
  transparentHeader?: boolean;
  /** 是否首页（配合 BACKGROUND_CONFIG.scope） */
  isHome?: boolean;
}

const {
  title,
  description = SITE_DESCRIPTION,
  locale = DEFAULT_LOCALE,
  ogSlug = "home",
  transparentHeader = false,
  isHome = false,
} = Astro.props;
const pageTitle = title ? `${title} · ${SITE_NAME_ZH}` : `${SITE_NAME_ZH} · ${SITE_TAGLINE}`;
const base = import.meta.env.BASE_URL;
const themeBoot = getThemeBootScript();
const a11yBoot = getA11yBootScript();
const year = new Date().getFullYear();
const canonical = absolutePageUrl(Astro.url.pathname);
const ogImageAbs = new URL(ogImagePath(ogSlug), resolveCanonicalOrigin()).href;
const webmentionEndpoint = resolveWebmentionEndpoint(readWebmentionEnvFromImportMeta());
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {webmentionEndpoint ? <link rel="webmention" href={webmentionEndpoint} /> : null}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME_ZH} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}og-default.png`} />
    <meta name="theme-color" content="#fbfbfd" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@500&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline set:html={themeBoot} />
    <script is:inline set:html={a11yBoot} />
    <Analytics />
  </head>
  <body class="min-h-screen font-sans antialiased">
    <!--
      壁纸放进 .site-chrome，与文案同层，ink-invert（difference）才能混到壁纸。
      壁纸须非负 z-index（见 docs/background.md）。
    -->
    <div class:list={["site-chrome relative z-10", isHome && "site-chrome--home"]}>
      <BackgroundLayer
        client:load
        isHome={isHome}
        prevLabel={translate(locale, "bg.prev")}
        nextLabel={translate(locale, "bg.next")}
        switcherLabel={translate(locale, "bg.switcher")}
      />
      <SplashScreen
        client:load
        brand={translate(locale, "splash.brand")}
        skipLabel={translate(locale, "splash.skip")}
        tagline={SITE_TAGLINE}
      />
      <a
        href="#main"
        class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-md focus:bg-hl-bg focus:px-3 focus:py-2 focus:text-hl-fg focus:shadow"
      >
        {translate(locale, "skip.toMain")}
      </a>
      <SiteHeader locale={locale} transparent={transparentHeader} />
      <main id="main" data-pagefind-body data-pagefind-meta={`title:${pageTitle}`}>
        <slot name="hero" />
        {
          Astro.slots.has("default") ? (
            <div
              class:list={[
                "page-shell",
                transparentHeader ? "pt-0 pb-12 md:pb-16" : "py-10 md:py-14",
              ]}
            >
              <slot />
            </div>
          ) : null
        }
      </main>
      <footer
        id="site-footer"
        class:list={[
          "site-footer page-shell scroll-mt-24",
          isHome && "site-footer--on-media",
        ]}
        data-pagefind-ignore
      >
        <div class="site-footer__inner">
          <div class="site-footer__row">
            <p class:list={["site-footer__mark", isHome && "ink-invert"]}>
              {SITE_NAME_ZH}
            </p>
            <div class="site-footer__end">
              <NowPlaying locale={locale} onMedia={isHome} />
              <p class:list={["site-footer__meta", isHome && "ink-invert"]}>
                <span>{translate(locale, "footer.rights", { year })}</span>
                <span class="site-footer__dot" aria-hidden="true">·</span>
                <span>{translate(locale, "footer.license")}</span>
              </p>
            </div>
          </div>
        </div>
      </footer>
      <SiteFab
        client:load
        locale={locale}
        prefsTitle={translate(locale, "about.prefs")}
        prefsHint={translate(locale, "about.prefsHint")}
        prefsOpenLabel={translate(locale, "prefs.open")}
        prefsCloseLabel={translate(locale, "prefs.close")}
        topLabel={translate(locale, "top.label")}
        helpTitle={translate(locale, "a11y.helpTitle")}
        helpOpenLabel={translate(locale, "a11y.helpOpen")}
        helpCloseLabel={translate(locale, "a11y.helpClose")}
        helpBody={translate(locale, "a11y.helpBody")}
        themeHeading={translate(locale, "theme.heading")}
        themeHint={translate(locale, "theme.hint")}
        langHeading={translate(locale, "lang.heading")}
        langHint={translate(locale, "lang.hint")}
        langSwitched={translate(locale, "lang.switched")}
        densityHeading={translate(locale, "a11y.density")}
        densityHint={translate(locale, "a11y.densityHint")}
        comfortableLabel={translate(locale, "a11y.comfortable")}
        defaultLabel={translate(locale, "a11y.default")}
        contrastHeading={translate(locale, "a11y.contrast")}
        contrastOn={translate(locale, "a11y.contrastOn")}
        contrastOff={translate(locale, "a11y.contrastOff")}
      />
    </div>
  </body>
</html>
