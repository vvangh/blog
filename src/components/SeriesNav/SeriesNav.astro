---
/**
 * 系列课式上一篇 / 下一篇。
 */
interface LinkItem {
  href: string;
  title: string;
}

interface Props {
  seriesLabel: string;
  seriesName: string;
  prevLabel: string;
  nextLabel: string;
  prev: LinkItem | null;
  next: LinkItem | null;
}

const { seriesLabel, seriesName, prevLabel, nextLabel, prev, next } = Astro.props;
---

<nav
  class="mt-10 grid gap-4 border-t border-hl-border pt-6 sm:grid-cols-2"
  aria-label={seriesLabel}
  data-pagefind-ignore
>
  <p class="sm:col-span-2 text-sm text-hl-muted">
    {seriesLabel}：<span class="font-medium text-hl-fg">{seriesName}</span>
  </p>
  {
    prev ? (
      <a
        class="rounded-lg border border-hl-border p-3 no-underline transition hover:border-hl-accent"
        href={prev.href}
        rel="prev"
      >
        <span class="block text-xs text-hl-muted">{prevLabel}</span>
        <span class="mt-1 block font-medium text-hl-accent">{prev.title}</span>
      </a>
    ) : (
      <div />
    )
  }
  {
    next ? (
      <a
        class="rounded-lg border border-hl-border p-3 text-right no-underline transition hover:border-hl-accent sm:justify-self-end"
        href={next.href}
        rel="next"
      >
        <span class="block text-xs text-hl-muted">{nextLabel}</span>
        <span class="mt-1 block font-medium text-hl-accent">{next.title}</span>
      </a>
    ) : null
  }
</nav>
