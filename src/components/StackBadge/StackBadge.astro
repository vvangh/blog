---
/**
 * 今日栈小组件。
 */
import { readStackFromPackageJson } from "@/lib/stack";
import { translate, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = readStackFromPackageJson();
---

<section class="rounded-xl border border-hl-border bg-hl-panel p-4" aria-labelledby="stack-heading">
  <h2 id="stack-heading" class="m-0 text-lg font-semibold">{translate(locale, "stack.title")}</h2>
  <ul class="mt-3 flex flex-wrap gap-2 font-mono text-sm">
    {
      items.map((item) => (
        <li class="rounded-md border border-hl-border px-2 py-1">
          {item.name} {item.version}
        </li>
      ))
    }
  </ul>
</section>
