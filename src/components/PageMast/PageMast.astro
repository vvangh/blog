---
/**
 * 分区页首：kicker + 大标题 + 描述，全站统一节奏。
 * 额外内容（统计、快捷入口等）经默认 slot 追加。
 */
interface Props {
  /** 英文装饰标签（mono 大写），如 "BLOG" */
  kicker: string;
  title: string;
  description?: string;
  class?: string;
}

const { kicker, title, description, class: className } = Astro.props;
---

<header class:list={["page-mast mb-12", className]}>
  <p class="section-kicker">{kicker}</p>
  <h1 class="section-title section-title--lg">{title}</h1>
  {description ? <p class="mt-5 text-lg leading-relaxed text-hl-muted">{description}</p> : null}
  <slot />
</header>
