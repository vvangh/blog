---
/**
 * ADR 关系图（静态 SVG）。
 */
import { ADR_EDGES, ADR_NODES } from "@/lib/adr";
import { translate, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const width = 640;
const height = Math.max(180, ADR_NODES.length * 56);
---

<section class="mt-10 space-y-3" aria-labelledby="adr-heading" data-pagefind-ignore>
  <div>
    <h2 id="adr-heading" class="text-lg font-semibold">{translate(locale, "adr.title")}</h2>
    <p class="mt-1 text-sm text-hl-muted">{translate(locale, "adr.hint")}</p>
  </div>
  <svg
    class="w-full rounded-lg border border-hl-border bg-hl-panel"
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-label={translate(locale, "adr.title")}
  >
    {
      ADR_EDGES.map((edge) => {
        const fromIdx = ADR_NODES.findIndex((n) => n.id === edge.from);
        const toIdx = ADR_NODES.findIndex((n) => n.id === edge.to);
        if (fromIdx < 0 || toIdx < 0) return null;
        const y1 = 28 + fromIdx * 56;
        const y2 = 28 + toIdx * 56;
        return (
          <line
            x1={200}
            y1={y1}
            x2={200}
            y2={y2}
            stroke="var(--hl-accent)"
            stroke-width="2"
            marker-end="url(#arrow)"
          />
        );
      })
    }
    <defs>
      <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="var(--hl-accent)"></path>
      </marker>
    </defs>
    {
      ADR_NODES.map((node, i) => {
        const y = 12 + i * 56;
        const fill =
          node.status === "accepted"
            ? "var(--hl-accent)"
            : node.status === "superseded"
              ? "var(--hl-muted)"
              : "var(--hl-accent-2)";
        return (
          <g>
            <rect x="24" y={y} width="360" height="40" rx="8" fill="var(--hl-bg)" stroke={fill} />
            <text x="40" y={y + 26} fill="var(--hl-fg)" font-size="14">
              {node.id}: {node.title} ({node.status})
            </text>
          </g>
        );
      })
    }
  </svg>
  <ul class="space-y-1 text-sm text-hl-muted">
    {
      ADR_EDGES.map((e) => (
        <li>
          <span class="font-mono">{e.from}</span> —{e.rel}→ <span class="font-mono">{e.to}</span>
        </li>
      ))
    }
  </ul>
</section>
