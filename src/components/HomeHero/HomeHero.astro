---
/**
 * 首页全出血 Hero：壁纸全露；文案 ink-invert（difference 自动反色）。
 * 入场动效包在外层，避免 transform 留在 ink-invert 上干扰混色。
 */
import { SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";
import { localePath, translate, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="home-hero" aria-labelledby="hero-brand">
  <div class="home-hero__stage">
    <div class="page-shell home-hero__content">
      <div class="motion-safe-rise" style="animation-delay: 0.08s">
        <p class="home-hero__eyebrow ink-invert">
          {translate(locale, "home.eyebrow")}
        </p>
      </div>

      <div class="motion-safe-rise mt-5" style="animation-delay: 0.18s">
        <h1
          id="hero-brand"
          class="ink-invert brand-mark text-[clamp(4.25rem,15vw,8.5rem)]"
        >
          {SITE_NAME_ZH}
        </h1>
      </div>

      <div class="motion-safe-rise mt-7" style="animation-delay: 0.3s">
        <p
          class="max-w-lg text-[1.65rem] leading-snug font-medium tracking-tight md:text-[2rem]"
        >
          <span class="ink-invert">{SITE_TAGLINE}</span>
          <span class="home-hero__cursor" aria-hidden="true"></span>
        </p>
      </div>

      <div class="motion-safe-rise mt-4" style="animation-delay: 0.42s">
        <p class="home-hero__lead ink-invert">
          {translate(locale, "home.lead")}
        </p>
      </div>

      <div class="motion-safe-rise mt-10 flex flex-wrap gap-3" style="animation-delay: 0.54s">
        <a class="btn-cta" href={localePath(locale, "blog")}>
          {translate(locale, "nav.blog")}
        </a>
        <a class="btn-ghost btn-ghost--on-media" href={localePath(locale, "life")}>
          {translate(locale, "nav.life")}
        </a>
      </div>
    </div>
  </div>
</section>
