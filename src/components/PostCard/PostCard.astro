---
/**
 * 文章/日志列表项：编辑式排版（日期左、标题右），非卡片墙。
 * hover 轻微抬升阴影，避免做成 POETIZE 式封面卡网格。
 */
import { formatDate } from "@/lib/date";

interface Props {
  href: string;
  title: string;
  description?: string;
  date: Date;
  locale?: string;
  meta?: string;
}

const { href, title, description, date, locale = "zh-Hans", meta } = Astro.props;
---

<article
  class="motion-safe-card group grid gap-3 border-b border-hl-border py-7 first:pt-0 sm:grid-cols-[7.5rem_minmax(0,1fr)] sm:gap-8"
>
  <p class="font-mono text-xs tracking-wide text-hl-muted sm:pt-2">
    <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
  </p>
  <div>
    <h2 class="font-display text-xl font-bold tracking-tight md:text-2xl">
      <a class="text-hl-fg no-underline transition-colors group-hover:text-hl-accent" href={href}>
        {title}
      </a>
    </h2>
    {
      meta ? (
        <p class="mt-2 font-mono text-[0.7rem] tracking-[0.22em] text-hl-accent uppercase">{meta}</p>
      ) : null
    }
    {
      description ? (
        <p class="mt-3 max-w-prose leading-relaxed text-hl-muted">{description}</p>
      ) : null
    }
  </div>
</article>
