---
/**
 * 站点顶栏（vv Air）：轻字标 + 灰链导航 + 磨砂双态。
 */
import { SITE_NAME_ZH } from "@/lib/site";
import { localePath, translate, type Locale } from "@/lib/i18n";
import { SiteSearch } from "@/components/SiteSearch";
import HeaderScrollState from "./HeaderScrollState.vue";

interface Props {
  locale: Locale;
  transparent?: boolean;
}

const { locale, transparent = false } = Astro.props;
const primary = [
  { href: localePath(locale, "blog"), label: translate(locale, "nav.blog") },
  { href: localePath(locale, "build"), label: translate(locale, "nav.build") },
  { href: localePath(locale, "life"), label: translate(locale, "nav.life") },
  { href: localePath(locale, "about"), label: translate(locale, "nav.about") },
];
const more = [
  { href: localePath(locale, "lab"), label: translate(locale, "nav.lab") },
  { href: localePath(locale, "archive"), label: translate(locale, "nav.archive") },
  { href: localePath(locale, "friends"), label: translate(locale, "nav.friends") },
  { href: localePath(locale, "fun"), label: translate(locale, "nav.fun") },
];
---

<header
  class:list={["site-header sticky top-0 z-40", transparent && "site-header--transparent"]}
  data-site-header
  data-transparent={transparent ? "true" : "false"}
  data-pagefind-ignore
>
  {transparent ? <HeaderScrollState client:load /> : null}

  <div class="page-shell flex items-center justify-between gap-4 py-3">
    <a
      href={localePath(locale)}
      class="brand-mark text-[1.35rem] text-hl-fg no-underline transition-opacity hover:opacity-70"
      aria-label={SITE_NAME_ZH}
    >
      {SITE_NAME_ZH}
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <nav aria-label={translate(locale, "nav.main")} class="hidden md:block">
        <ul class="flex items-center gap-0.5 text-[0.9375rem] font-normal">
          {
            primary.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="motion-safe-nav-link site-header__link inline-flex min-h-10 items-center rounded-full px-3 no-underline"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="relative">
            <details class="group/more">
              <summary
                class="motion-safe-nav-link site-header__link inline-flex min-h-10 cursor-pointer list-none items-center rounded-full px-3 no-underline marker:content-none [&::-webkit-details-marker]:hidden"
              >
                {translate(locale, "nav.more")}
              </summary>
              <ul
                class="glass-panel absolute right-0 z-50 mt-2 min-w-36 rounded-2xl p-1.5"
              >
                {
                  more.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="block rounded-xl px-3 py-2 text-hl-fg no-underline hover:bg-hl-soft hover:text-hl-accent"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </details>
          </li>
        </ul>
      </nav>

      <nav aria-label={translate(locale, "nav.main")} class="max-w-[52vw] overflow-x-auto md:hidden">
        <ul class="flex items-center gap-0.5 text-sm font-normal whitespace-nowrap">
          {
            [...primary, ...more].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="site-header__link inline-flex min-h-10 items-center rounded-full px-2.5 no-underline"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <SiteSearch
        client:load
        openLabel={translate(locale, "search.open")}
        title={translate(locale, "search.title")}
        placeholder={translate(locale, "search.placeholder")}
        empty={translate(locale, "search.empty")}
        noIndex={translate(locale, "search.noIndex")}
        closeLabel={translate(locale, "search.close")}
      />
    </div>
  </div>
</header>
