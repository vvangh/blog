---
/**
 * 站点顶栏：品牌字标 + 主导航 + 次要折叠 + 搜索。
 * 主链精简，避免模板站「全链堆顶栏」的观感。
 */
import { SITE_NAME_ZH } from "@/lib/site";
import { localePath, translate, type Locale } from "@/lib/i18n";
import { SiteSearch } from "@/components/SiteSearch";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const primary = [
  { href: localePath(locale, "blog"), label: translate(locale, "nav.blog") },
  { href: localePath(locale, "build"), label: translate(locale, "nav.build") },
  { href: localePath(locale, "life"), label: translate(locale, "nav.life") },
  { href: localePath(locale, "about"), label: translate(locale, "nav.about") },
];
const more = [
  { href: localePath(locale, "lab"), label: translate(locale, "nav.lab") },
  { href: localePath(locale, "archive"), label: translate(locale, "nav.archive") },
  { href: localePath(locale, "friends"), label: translate(locale, "nav.friends") },
  { href: localePath(locale, "fun"), label: translate(locale, "nav.fun") },
];
---

<header
  class="sticky top-0 z-40 border-b border-hl-border/80 bg-hl-bg/75 backdrop-blur-xl"
  data-pagefind-ignore
>
  <div class="page-shell flex items-center justify-between gap-4 py-3.5">
    <a
      href={localePath(locale)}
      class="brand-mark inline-flex flex-col gap-1 text-[1.75rem] text-hl-fg no-underline transition-opacity hover:opacity-80"
      aria-label={SITE_NAME_ZH}
    >
      <span class="leading-none">{SITE_NAME_ZH}</span>
      <span class="block h-[3px] w-full bg-hl-accent" aria-hidden="true"></span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <nav aria-label={translate(locale, "nav.main")} class="hidden md:block">
        <ul class="flex items-center gap-0.5 text-sm font-medium">
          {
            primary.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="motion-safe-nav-link inline-flex min-h-10 items-center rounded-full px-3 text-hl-fg/90 no-underline hover:bg-hl-soft hover:text-hl-accent"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="relative">
            <details class="group/more">
              <summary
                class="motion-safe-nav-link inline-flex min-h-10 cursor-pointer list-none items-center rounded-full px-3 text-hl-muted no-underline marker:content-none hover:bg-hl-soft hover:text-hl-accent [&::-webkit-details-marker]:hidden"
              >
                {translate(locale, "nav.more")}
              </summary>
              <ul
                class="absolute right-0 z-50 mt-2 min-w-36 rounded-xl border border-hl-border bg-hl-panel p-1.5 shadow-lg"
              >
                {
                  more.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="block rounded-lg px-3 py-2 text-hl-fg no-underline hover:bg-hl-soft hover:text-hl-accent"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </details>
          </li>
        </ul>
      </nav>

      {/* 小屏：横向可滚主链 */}
      <nav aria-label={translate(locale, "nav.main")} class="max-w-[52vw] overflow-x-auto md:hidden">
        <ul class="flex items-center gap-0.5 text-sm font-medium whitespace-nowrap">
          {
            [...primary, ...more].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-flex min-h-10 items-center rounded-full px-2.5 text-hl-fg/90 no-underline hover:text-hl-accent"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <SiteSearch
        client:load
        openLabel={translate(locale, "search.open")}
        title={translate(locale, "search.title")}
        placeholder={translate(locale, "search.placeholder")}
        empty={translate(locale, "search.empty")}
        noIndex={translate(locale, "search.noIndex")}
        closeLabel={translate(locale, "search.close")}
      />
    </div>
  </div>
</header>
