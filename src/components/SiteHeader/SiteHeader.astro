---
/**
 * 站点顶栏：印章式品牌 + 墨线下划线导航。
 */
import { SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";
import { localePath, translate, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const links = [
  { href: localePath(locale), label: translate(locale, "nav.home") },
  { href: localePath(locale, "blog"), label: translate(locale, "nav.blog") },
  { href: localePath(locale, "build"), label: translate(locale, "nav.build") },
  { href: localePath(locale, "life"), label: translate(locale, "nav.life") },
  { href: localePath(locale, "fun"), label: translate(locale, "nav.fun") },
];
---

<header class="site-header">
  <div class="mx-auto flex max-w-5xl flex-wrap items-end justify-between gap-4 px-4 py-5">
    <div>
      <a href={localePath(locale)} class="site-brand">{SITE_NAME_ZH}</a>
      <p class="mt-1 max-w-xs text-sm text-[var(--henglu-muted)]">{SITE_TAGLINE}</p>
    </div>
    <nav class="site-nav" aria-label={translate(locale, "nav.main")}>
      <ul class="flex flex-wrap gap-5 text-sm tracking-wide">
        {
          links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
