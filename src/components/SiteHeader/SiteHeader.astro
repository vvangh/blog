---
/**
 * 站点顶栏：品牌 + 导航 + 搜索。
 */
import { SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";
import { localePath, translate, type Locale } from "@/lib/i18n";
import { SiteSearch } from "@/components/SiteSearch";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const links = [
  { href: localePath(locale), label: translate(locale, "nav.home") },
  { href: localePath(locale, "blog"), label: translate(locale, "nav.blog") },
  { href: localePath(locale, "build"), label: translate(locale, "nav.build") },
  { href: localePath(locale, "archive"), label: translate(locale, "nav.archive") },
  { href: localePath(locale, "about"), label: translate(locale, "nav.about") },
  { href: localePath(locale, "friends"), label: translate(locale, "nav.friends") },
];
---

<header
  class="sticky top-0 z-40 border-b border-hl-border bg-hl-bg/80 backdrop-blur-md"
  data-pagefind-ignore
>
  <div class="mx-auto flex max-w-5xl flex-wrap items-end justify-between gap-4 px-4 py-4">
    <div>
      <a
        href={localePath(locale)}
        class="font-display text-2xl font-semibold tracking-tight text-hl-fg no-underline transition-opacity hover:opacity-80"
      >
        {SITE_NAME_ZH}
      </a>
      <p class="mt-1 max-w-xs text-sm text-hl-muted">{SITE_TAGLINE}</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <nav aria-label={translate(locale, "nav.main")}>
        <ul class="flex flex-wrap gap-1 text-sm font-medium tracking-wide">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="motion-safe-nav-link inline-flex min-h-10 items-center rounded-md px-3 text-hl-fg no-underline transition-colors hover:bg-hl-soft hover:text-hl-accent"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <SiteSearch
        client:load
        openLabel={translate(locale, "search.open")}
        title={translate(locale, "search.title")}
        placeholder={translate(locale, "search.placeholder")}
        empty={translate(locale, "search.empty")}
        noIndex={translate(locale, "search.noIndex")}
        closeLabel={translate(locale, "search.close")}
      />
    </div>
  </div>
</header>
