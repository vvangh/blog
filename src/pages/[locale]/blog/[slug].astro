---
/**
 * 技术博客详情：听读、修订、系列、目录、进度、评论。
 */
import { getCollection, render } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout";
import { publishedSorted } from "@/content/_helpers";
import { formatDate } from "@/lib/date";
import { estimateReadingMinutes } from "@/lib/reading";
import { resolveSeriesNav } from "@/lib/series";
import { LOCALES, isLocale, localePath, translate, type Locale } from "@/lib/i18n";
import { filterTocHeadings } from "@/lib/toc";
import { PostToc } from "@/components/PostToc";
import { ReadingProgress } from "@/components/ReadingProgress";
import { GiscusComments } from "@/components/GiscusComments";
import { ReadAloud } from "@/components/ReadAloud";
import { RevisionTimeline } from "@/components/RevisionTimeline";
import { SeriesNav } from "@/components/SeriesNav";
import { CiteCopy } from "@/components/CiteCopy";
import { Webmentions } from "@/components/Webmentions";
import { SITE_NAME_ZH } from "@/lib/site";
import { absolutePageUrl } from "@/lib/og";

export async function getStaticPaths() {
  const entries = publishedSorted(await getCollection("blog"));
  return LOCALES.flatMap((locale) =>
    entries.map((entry) => ({
      params: { locale, slug: entry.id },
      props: { entry },
    })),
  );
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) throw new Error(`Unsupported locale: ${raw}`);
const locale: Locale = raw;
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const tocItems = filterTocHeadings(headings);

const allBlog = publishedSorted(await getCollection("blog"));
const seriesNav = resolveSeriesNav(
  entry.id,
  allBlog.map((e) => ({
    id: e.id,
    title: e.data.title,
    series: e.data.series,
    seriesOrder: e.data.seriesOrder,
  })),
);

const bodyText = `${entry.data.title}\n${entry.data.description ?? ""}\n${entry.body ?? ""}`;
const reading = estimateReadingMinutes(bodyText);
const pageUrl = absolutePageUrl(Astro.url.pathname);
const citation = `《${entry.data.title}》· ${SITE_NAME_ZH} · ${pageUrl}`;
---

<SiteLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  ogSlug="blog"
>
  <ReadingProgress client:load label={translate(locale, "progress.label")} />
  <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_15rem] lg:gap-14" data-reading-root>
    <article>
      <p class="mb-8">
        <a
          class="inline-flex items-center gap-1 text-sm font-medium text-hl-muted no-underline transition hover:text-hl-accent"
          href={localePath(locale, "blog")}
        >
          ← {translate(locale, "nav.blog")}
        </a>
      </p>
      <header class="mb-12 space-y-5 border-b border-hl-border pb-10">
        {
          entry.data.tags?.[0] ? (
            <p class="font-mono text-[0.7rem] tracking-[0.28em] text-hl-accent uppercase">
              {entry.data.tags[0]}
            </p>
          ) : null
        }
        <h1 class="font-display text-[clamp(2rem,5vw,3.25rem)] leading-[1.1] font-bold tracking-tight">
          {entry.data.title}
        </h1>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-hl-muted">
          <time datetime={entry.data.pubDate.toISOString()}>
            {formatDate(entry.data.pubDate, locale)}
          </time>
        </div>
        {entry.data.description ? <p class="max-w-2xl text-lg text-hl-muted">{entry.data.description}</p> : null}
        <div class="pt-2">
          <ReadAloud
            client:load
            minutes={reading.minutes}
            minutesLabel={translate(locale, "readAloud.minutes")}
            startLabel={translate(locale, "readAloud.start")}
            stopLabel={translate(locale, "readAloud.stop")}
            unsupportedLabel={translate(locale, "readAloud.unsupported")}
          />
        </div>
      </header>
      <div class="content-body" data-read-aloud-root>
        <Content />
      </div>
      <div class="mt-14 space-y-10 border-t border-hl-border pt-10">
        <RevisionTimeline
          title={translate(locale, "revisions.title")}
          revisions={[...entry.data.revisions]
            .sort((a, b) => a.date.valueOf() - b.date.valueOf())
            .map((rev) => ({
              iso: rev.date.toISOString(),
              label: formatDate(rev.date, locale),
              summary: rev.summary,
            }))}
        />
        {
          seriesNav ? (
            <SeriesNav
              seriesLabel={translate(locale, "series.label")}
              seriesName={seriesNav.series}
              prevLabel={translate(locale, "series.prev")}
              nextLabel={translate(locale, "series.next")}
              prev={
                seriesNav.prev
                  ? {
                      href: localePath(locale, `blog/${seriesNav.prev.id}`),
                      title: seriesNav.prev.title,
                    }
                  : null
              }
              next={
                seriesNav.next
                  ? {
                      href: localePath(locale, `blog/${seriesNav.next.id}`),
                      title: seriesNav.next.title,
                    }
                  : null
              }
            />
          ) : null
        }
        <CiteCopy
          client:load
          label={translate(locale, "cite.label")}
          copyLabel={translate(locale, "cite.copy")}
          copiedLabel={translate(locale, "cite.copied")}
          citation={citation}
        />
        <Webmentions
          title={translate(locale, "webmentions.title")}
          empty={translate(locale, "webmentions.empty")}
          disabled={translate(locale, "webmentions.disabled")}
          pageUrl={pageUrl}
        />
        <GiscusComments locale={locale} heading={translate(locale, "comments.title")} />
      </div>
    </article>
    {
      tocItems.length > 0 ? (
        <aside class="mt-12 lg:mt-0" data-pagefind-ignore>
          <div class="rounded-2xl border border-hl-border bg-hl-panel/70 p-4 backdrop-blur-sm lg:sticky lg:top-28">
            <PostToc client:load title={translate(locale, "toc.title")} items={tocItems} />
          </div>
        </aside>
      ) : null
    }
  </div>
</SiteLayout>
