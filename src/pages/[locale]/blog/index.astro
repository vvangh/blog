---
/**
 * 技术博客列表：页首（计数 + RSS）+ 标签速览 + 编辑式文章列表。
 */
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout";
import { PageMast } from "@/components/PageMast";
import { PostCard } from "@/components/PostCard";
import { publishedSorted } from "@/content/_helpers";
import { toTagParam } from "@/lib/tags";
import { Rss, Tag } from "@lucide/vue";
import { LOCALES, isLocale, localePath, translate, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) throw new Error(`Unsupported locale: ${raw}`);
const locale: Locale = raw;
const entries = publishedSorted(await getCollection("blog"));

const tagCounts = new Map<string, number>();
for (const e of entries) {
  for (const t of e.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh"))
  .slice(0, 8)
  .map(([tag]) => tag);
---

<SiteLayout title={translate(locale, "blog.title")} locale={locale} ogSlug="blog">
  <PageMast
    kicker="Blog"
    title={translate(locale, "blog.title")}
    description={translate(locale, "blog.intro")}
  >
    <div class="mt-6 flex flex-wrap items-center gap-3">
      <span class="glass-chip-soft inline-flex items-center px-4 py-2 text-sm text-hl-muted">
        {translate(locale, "posts.count", { count: entries.length })}
      </span>
      <a
        class="glass-chip-soft inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-hl-fg no-underline transition-colors hover:text-hl-accent"
        href={`${import.meta.env.BASE_URL}${locale}/rss.xml`}
      >
        <Rss class="size-3.5 text-hl-accent" aria-hidden="true" />
        RSS
      </a>
      {
        topTags.map((tag) => (
          <a
            class="glass-chip-soft inline-flex items-center gap-1.5 px-4 py-2 text-sm text-hl-fg no-underline transition-colors hover:text-hl-accent"
            href={localePath(locale, `tags/${toTagParam(tag)}`)}
          >
            <Tag class="size-3 text-hl-muted" aria-hidden="true" />
            {tag}
          </a>
        ))
      }
    </div>
  </PageMast>

  {
    entries.length === 0 ? (
      <p class="text-hl-muted">{translate(locale, "blog.empty")}</p>
    ) : (
      <div class="home-deck__list">
        {entries.map((entry) => (
          <PostCard
            href={localePath(locale, `blog/${entry.id}`)}
            title={entry.data.title}
            description={entry.data.description}
            date={entry.data.pubDate}
            locale={locale}
            meta={entry.data.tags?.[0]}
          />
        ))}
      </div>
    )
  }
</SiteLayout>
