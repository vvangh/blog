---
/**
 * 技术博客列表。
 */
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout";
import { PostCard } from "@/components/PostCard";
import { publishedSorted } from "@/content/_helpers";
import { LOCALES, isLocale, localePath, translate, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) throw new Error(`Unsupported locale: ${raw}`);
const locale: Locale = raw;
const entries = publishedSorted(await getCollection("blog"));
---

<SiteLayout title={translate(locale, "blog.title")} locale={locale} ogSlug="blog">
  <header class="mb-12 max-w-2xl space-y-4">
    <p class="font-mono text-xs tracking-[0.35em] text-hl-accent uppercase">Blog</p>
    <h1 class="font-display text-4xl font-bold tracking-tight md:text-5xl">
      {translate(locale, "blog.title")}
    </h1>
    <p class="text-sm text-hl-muted">
      <a
        class="font-medium text-hl-accent no-underline hover:underline"
        href={`${import.meta.env.BASE_URL}${locale}/rss.xml`}
      >
        RSS
      </a>
    </p>
  </header>
  {
    entries.length === 0 ? (
      <p class="text-hl-muted">{translate(locale, "blog.empty")}</p>
    ) : (
      <div>
        {entries.map((entry) => (
          <PostCard
            href={localePath(locale, `blog/${entry.id}`)}
            title={entry.data.title}
            description={entry.data.description}
            date={entry.data.pubDate}
            locale={locale}
            meta={entry.data.tags?.[0]}
          />
        ))}
      </div>
    )
  }
</SiteLayout>
