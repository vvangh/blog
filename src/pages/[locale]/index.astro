---
/**
 * 首页：仅全出血 Hero + 布局页脚，中间不挂列表/频道/订阅。
 */
import SiteLayout from "@/layouts/SiteLayout";
import { HomeHero } from "@/components/HomeHero";
import { LOCALES, isLocale, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) {
  throw new Error(`Unsupported locale: ${raw}`);
}
const locale: Locale = raw;
---

<SiteLayout locale={locale} ogSlug="home" transparentHeader isHome>
  <HomeHero slot="hero" locale={locale} />
</SiteLayout>
