---
/**
 * 首页：品牌首屏 + 最近写作 + 频道入口。
 * 设置类控件迁至「关于」，避免首屏像后台模板。
 */
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout";
import { PostCard } from "@/components/PostCard";
import { NewsletterSignup } from "@/components/NewsletterSignup";
import { publishedSorted } from "@/content/_helpers";
import { LOCALES, isLocale, localePath, translate, type Locale } from "@/lib/i18n";
import { SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) {
  throw new Error(`Unsupported locale: ${raw}`);
}
const locale: Locale = raw;
const latest = publishedSorted(await getCollection("blog")).slice(0, 3);
---

<SiteLayout locale={locale} ogSlug="home">
  <section
    class="relative overflow-hidden pt-10 pb-14 md:pt-16 md:pb-20"
    aria-labelledby="hero-brand"
  >
    <div
      class="motion-safe-glow pointer-events-none absolute -top-8 -right-20 h-72 w-72 rounded-full bg-hl-accent/25 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute bottom-10 left-0 h-40 w-40 rounded-full bg-hl-accent-2/15 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <p
      class="motion-safe-rise font-mono text-[0.7rem] font-medium tracking-[0.42em] text-hl-accent uppercase"
      style="animation-delay: 0.04s"
    >
      {translate(locale, "home.eyebrow")}
    </p>

    <h1
      id="hero-brand"
      class="brand-mark motion-safe-rise mt-4 text-[clamp(3.75rem,14vw,7.5rem)] text-hl-fg"
      style="animation-delay: 0.1s"
    >
      {SITE_NAME_ZH}
    </h1>
    <span
      class="motion-safe-underline mt-3 block h-[3px] w-20 bg-hl-accent md:w-28"
      aria-hidden="true"
    ></span>

    <p
      class="motion-safe-rise mt-6 max-w-lg text-xl text-hl-muted md:text-2xl"
      style="animation-delay: 0.22s"
    >
      {SITE_TAGLINE}
    </p>

    <div class="motion-safe-rise mt-8 flex flex-wrap gap-3" style="animation-delay: 0.3s">
      <a
        class="inline-flex min-h-12 items-center justify-center rounded-full bg-hl-accent px-6 font-semibold text-white no-underline shadow-[0_12px_40px_-16px_var(--hl-accent)] transition hover:-translate-y-0.5 hover:brightness-110 focus-visible:outline-hl-focus"
        href={localePath(locale, "blog")}
      >
        {translate(locale, "nav.blog")}
      </a>
      <a
        class="inline-flex min-h-12 items-center justify-center rounded-full border border-hl-border bg-hl-panel/60 px-6 font-medium text-hl-fg no-underline backdrop-blur-sm transition hover:border-hl-accent hover:text-hl-accent"
        href={localePath(locale, "build")}
      >
        {translate(locale, "nav.build")}
      </a>
    </div>
  </section>

  <p class="max-w-xl text-base leading-relaxed text-hl-muted">
    {translate(locale, "home.intro")}
  </p>

  {
    latest.length > 0 ? (
      <section class="border-t border-hl-border pt-14" aria-labelledby="latest-heading">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-3">
          <h2 id="latest-heading" class="font-display text-2xl font-bold tracking-tight md:text-3xl">
            {translate(locale, "home.latest")}
          </h2>
          <a
            class="text-sm font-medium text-hl-accent no-underline hover:underline"
            href={localePath(locale, "blog")}
          >
            {translate(locale, "home.viewAll")} →
          </a>
        </div>
        <div>
          {latest.map((entry) => (
            <PostCard
              href={localePath(locale, `blog/${entry.id}`)}
              title={entry.data.title}
              description={entry.data.description}
              date={entry.data.pubDate}
              locale={locale}
              meta={entry.data.tags?.[0]}
            />
          ))}
        </div>
      </section>
    ) : null
  }

  <section
    class="mt-16 grid gap-10 border-t border-hl-border pt-14 md:grid-cols-3"
    aria-label={SITE_TAGLINE}
  >
    <a class="group block no-underline" href={localePath(locale, "blog")}>
      <p class="font-mono text-xs tracking-[0.28em] text-hl-accent uppercase">{translate(locale, "nav.blog")}</p>
      <p class="mt-3 font-display text-xl font-bold text-hl-fg transition group-hover:text-hl-accent">
        {translate(locale, "blog.title")} →
      </p>
    </a>
    <a class="group block no-underline" href={localePath(locale, "life")}>
      <p class="font-mono text-xs tracking-[0.28em] text-hl-accent uppercase">{translate(locale, "nav.life")}</p>
      <p class="mt-3 font-display text-xl font-bold text-hl-fg transition group-hover:text-hl-accent">
        {translate(locale, "life.title")} →
      </p>
      <p class="mt-2 text-sm leading-relaxed text-hl-muted">{translate(locale, "life.intro")}</p>
    </a>
    <a class="group block no-underline" href={localePath(locale, "fun")}>
      <p class="font-mono text-xs tracking-[0.28em] text-hl-accent uppercase">{translate(locale, "nav.fun")}</p>
      <p class="mt-3 font-display text-xl font-bold text-hl-fg transition group-hover:text-hl-accent">
        {translate(locale, "fun.title")} →
      </p>
    </a>
  </section>

  <section class="mt-16 max-w-md border-t border-hl-border pt-14">
    <NewsletterSignup locale={locale} />
  </section>
</SiteLayout>
