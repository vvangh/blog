---
/**
 * 标签云：聚合 blog / build-log 的 tags，按频次排序；链到单标签页。
 */
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout";
import { PageMast } from "@/components/PageMast";
import { publishedSorted } from "@/content/_helpers";
import { toTagParam } from "@/lib/tags";
import { LOCALES, isLocale, localePath, translate, type Locale } from "@/lib/i18n";

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) throw new Error(`Unsupported locale: ${raw}`);
const locale: Locale = raw;

const counts = new Map<string, number>();
for (const col of ["blog", "build-log"] as const) {
  for (const e of publishedSorted(await getCollection(col))) {
    for (const t of e.data.tags ?? []) {
      counts.set(t, (counts.get(t) ?? 0) + 1);
    }
  }
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh"));
---

<SiteLayout title={translate(locale, "tags.title")} locale={locale} ogSlug="blog">
  <PageMast
    kicker="Tags"
    title={translate(locale, "tags.title")}
    description={translate(locale, "tags.intro")}
  />

  {
    tags.length === 0 ? (
      <p class="text-hl-muted">{translate(locale, "tags.empty")}</p>
    ) : (
      <ul class="flex flex-wrap items-center gap-3">
        {tags.map(([tag, n], i) => (
          <li>
            <a
              class:list={[
                "glass-chip-soft inline-flex items-baseline gap-2 px-4 py-2 text-hl-fg no-underline transition-colors hover:text-hl-accent",
                i < 3 ? "text-base font-medium" : "text-sm",
              ]}
              href={localePath(locale, `tags/${toTagParam(tag)}`)}
              title={`${tag} (${n})`}
            >
              {tag}
              <span class="font-mono text-xs text-hl-muted">{n}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</SiteLayout>
