---
/**
 * 实验室：站内实验项目 + 仓库仪表盘。
 */
import SiteLayout from "@/layouts/SiteLayout";
import { PageMast } from "@/components/PageMast";
import { LAB_SNAPSHOT } from "@/lib/lab";
import { LIGHTHOUSE_SCORES } from "@/lib/lighthouse";
import { Activity, Gamepad2, Layers, BookOpen } from "@lucide/vue";
import { LOCALES, isLocale, localePath, translate, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) throw new Error(`Unsupported locale: ${raw}`);
const locale: Locale = raw;
const snap = LAB_SNAPSHOT;

const t = (key: Parameters<typeof translate>[1]) => translate(locale, key);

type Status = "live" | "wip" | "idea";
const statusMeta: Record<Status, { label: string; dot: string; text: string }> = {
  live: { label: t("lab.statusLive"), dot: "bg-hl-accent", text: "text-hl-accent" },
  wip: { label: t("lab.statusWip"), dot: "bg-hl-accent-2", text: "text-hl-accent-2" },
  idea: { label: t("lab.statusIdea"), dot: "bg-hl-muted", text: "text-hl-muted" },
};

const projects = [
  { icon: Activity, name: t("lab.projHeatmap"), desc: t("lab.projHeatmapDesc"), status: "live" as Status, href: localePath(locale, "archive") },
  { icon: Layers, name: t("lab.projRelated"), desc: t("lab.projRelatedDesc"), status: "live" as Status, href: localePath(locale, "blog") },
  { icon: BookOpen, name: t("lab.projReadAloud"), desc: t("lab.projReadAloudDesc"), status: "wip" as Status, href: localePath(locale, "blog") },
  { icon: Gamepad2, name: t("lab.projGames"), desc: t("lab.projGamesDesc"), status: "idea" as Status, href: localePath(locale, "fun") },
];

const repoFacts = [
  { label: "Repo", value: snap.repo },
  { label: "Branch", value: snap.defaultBranch },
  { label: "CI", value: snap.ciStatus },
  { label: "Tests", value: `unit ${snap.unitTests} · e2e ${snap.e2eTests}` },
];
---

<SiteLayout title={translate(locale, "lab.title")} locale={locale} ogSlug="build">
  <PageMast
    kicker="Lab"
    title={translate(locale, "lab.title")}
    description={translate(locale, "lab.hint")}
  />

  <section aria-labelledby="lab-projects">
    <p class="section-kicker" aria-hidden="true">{translate(locale, "lab.projectsTitle")}</p>
    <h2 id="lab-projects" class="sr-only">{translate(locale, "lab.projectsTitle")}</h2>
    <ul class="mt-5 grid gap-4 sm:grid-cols-2">
      {
        projects.map((p) => {
          const Icon = p.icon;
          const meta = statusMeta[p.status];
          return (
            <li>
              <a
                class="glass-panel group flex h-full flex-col rounded-3xl p-6 no-underline motion-safe:transition-transform motion-safe:duration-300 motion-safe:hover:-translate-y-0.5"
                href={p.href}
              >
                <span class="flex items-center justify-between">
                  <span class="flex size-11 items-center justify-center rounded-2xl bg-hl-soft">
                    <Icon class="size-5 text-hl-accent" aria-hidden="true" />
                  </span>
                  <span class={`inline-flex items-center gap-1.5 rounded-lg border border-hl-border px-2.5 py-1 text-xs font-medium ${meta.text}`}>
                    <span class={`size-1.5 rounded-full ${meta.dot}`} aria-hidden="true" />
                    {meta.label}
                  </span>
                </span>
                <span class="mt-4 font-display text-lg font-semibold text-hl-fg">{p.name}</span>
                <span class="mt-2 block text-sm leading-relaxed text-hl-muted">{p.desc}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  <section class="mt-14" aria-labelledby="lab-repo">
    <p class="section-kicker" aria-hidden="true">{translate(locale, "lab.repoTitle")}</p>
    <h2 id="lab-repo" class="sr-only">{translate(locale, "lab.repoTitle")}</h2>
    <dl class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        repoFacts.map((f) => (
          <div class="min-w-0 border-b border-hl-border pb-4">
            <dt class="text-xs font-medium tracking-wide text-hl-muted">{f.label}</dt>
            <dd class="mt-2 truncate font-mono text-sm text-hl-fg" title={f.value}>{f.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="mt-14" aria-labelledby="lab-tags">
    <h2 id="lab-tags" class="section-title">Tags</h2>
    <ul class="mt-5 flex flex-wrap gap-2 font-mono text-sm">
      {snap.tags.map((tag) => <li class="glass-chip-soft px-3 py-1.5 text-hl-fg">{tag}</li>)}
    </ul>
  </section>

  <section class="mt-14" aria-labelledby="lh-heading">
    <h2 id="lh-heading" class="section-title">{translate(locale, "lighthouse.title")}</h2>
    <p class="mt-2 text-sm text-hl-muted">{translate(locale, "lighthouse.hint")}</p>
    <div class="mt-5 overflow-x-auto border-b border-hl-border pb-4">
      <table class="w-full min-w-[32rem] text-left text-sm">
        <thead>
          <tr class="border-b border-hl-border text-hl-muted">
            <th class="py-2 pr-3 font-medium">M</th>
            <th class="py-2 pr-3 font-medium">Perf</th>
            <th class="py-2 pr-3 font-medium">A11y</th>
            <th class="py-2 pr-3 font-medium">BP</th>
            <th class="py-2 pr-3 font-medium">SEO</th>
          </tr>
        </thead>
        <tbody>
          {
            LIGHTHOUSE_SCORES.map((row) => (
              <tr class="border-b border-hl-border last:border-0">
                <td class="py-2.5 pr-3 font-mono text-hl-fg">{row.milestone}</td>
                <td class="py-2.5 pr-3 font-mono">{row.performance}</td>
                <td class="py-2.5 pr-3 font-mono">{row.accessibility}</td>
                <td class="py-2.5 pr-3 font-mono">{row.bestPractices}</td>
                <td class="py-2.5 pr-3 font-mono">{row.seo}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <p class="mt-8 text-xs text-hl-muted">Updated {snap.lastUpdated}</p>
</SiteLayout>
