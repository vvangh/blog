---
/**
 * 仓库仪表盘 /lab。
 */
import SiteLayout from "@/layouts/SiteLayout";
import { LAB_SNAPSHOT } from "@/lib/lab";
import { LIGHTHOUSE_SCORES } from "@/lib/lighthouse";
import { LOCALES, isLocale, translate, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const raw = Astro.params.locale ?? "zh-Hans";
if (!isLocale(raw)) throw new Error(`Unsupported locale: ${raw}`);
const locale: Locale = raw;
const snap = LAB_SNAPSHOT;
---

<SiteLayout title={translate(locale, "lab.title")} locale={locale} ogSlug="build">
  <header class="mb-8 space-y-2">
    <h1 class="text-3xl font-semibold">{translate(locale, "lab.title")}</h1>
    <p class="text-hl-muted">{translate(locale, "lab.hint")}</p>
  </header>

  <dl class="grid gap-4 sm:grid-cols-2">
    <div class="rounded-lg border border-hl-border p-4">
      <dt class="text-xs text-hl-muted">Repo</dt>
      <dd class="mt-1 font-mono">{snap.repo}</dd>
    </div>
    <div class="rounded-lg border border-hl-border p-4">
      <dt class="text-xs text-hl-muted">Branch</dt>
      <dd class="mt-1 font-mono">{snap.defaultBranch}</dd>
    </div>
    <div class="rounded-lg border border-hl-border p-4">
      <dt class="text-xs text-hl-muted">CI</dt>
      <dd class="mt-1 font-mono">{snap.ciStatus}</dd>
    </div>
    <div class="rounded-lg border border-hl-border p-4">
      <dt class="text-xs text-hl-muted">Tests</dt>
      <dd class="mt-1 font-mono">
        unit {snap.unitTests} · e2e {snap.e2eTests}
      </dd>
    </div>
  </dl>

  <section class="mt-10" aria-labelledby="tags-heading">
    <h2 id="tags-heading" class="text-lg font-semibold">Tags</h2>
    <ul class="mt-3 flex flex-wrap gap-2 font-mono text-sm">
      {snap.tags.map((tag) => <li class="rounded-md border border-hl-border px-2 py-1">{tag}</li>)}
    </ul>
  </section>

  <section class="mt-10" aria-labelledby="lh-heading">
    <h2 id="lh-heading" class="text-lg font-semibold">{translate(locale, "lighthouse.title")}</h2>
    <p class="mt-1 text-sm text-hl-muted">{translate(locale, "lighthouse.hint")}</p>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[32rem] text-left text-sm">
        <thead>
          <tr class="border-b border-hl-border text-hl-muted">
            <th class="py-2 pr-3 font-medium">M</th>
            <th class="py-2 pr-3 font-medium">Perf</th>
            <th class="py-2 pr-3 font-medium">A11y</th>
            <th class="py-2 pr-3 font-medium">BP</th>
            <th class="py-2 pr-3 font-medium">SEO</th>
          </tr>
        </thead>
        <tbody>
          {
            LIGHTHOUSE_SCORES.map((row) => (
              <tr class="border-b border-hl-border">
                <td class="py-2 pr-3 font-mono">{row.milestone}</td>
                <td class="py-2 pr-3 font-mono">{row.performance}</td>
                <td class="py-2 pr-3 font-mono">{row.accessibility}</td>
                <td class="py-2 pr-3 font-mono">{row.bestPractices}</td>
                <td class="py-2 pr-3 font-mono">{row.seo}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <p class="mt-8 text-xs text-hl-muted">Updated {snap.lastUpdated}</p>
</SiteLayout>
