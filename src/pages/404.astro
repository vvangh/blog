---
/**
 * 404：品牌友好的未找到页（GitHub Pages 需仓库设置自定义 404）。
 */
import { SITE_NAME_ZH, SITE_TAGLINE } from "@/lib/site";
import { localePath } from "@/lib/i18n";
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>未找到 · {SITE_NAME_ZH}</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
        font-family: Georgia, "Noto Serif SC", "Source Han Serif SC", serif;
        background: #121412;
        color: #f2efe8;
      }
      main {
        max-width: 28rem;
        text-align: center;
      }
      .brand {
        color: #7eb6a4;
        letter-spacing: 0.08em;
      }
      a {
        color: #7eb6a4;
      }
    </style>
  </head>
  <body>
    <main>
      <p class="brand">{SITE_NAME_ZH}</p>
      <h1>这里没有这一页</h1>
      <p>{SITE_TAGLINE}</p>
      <p><a href={localePath("zh-Hans")}>回首页</a></p>
    </main>
  </body>
</html>
